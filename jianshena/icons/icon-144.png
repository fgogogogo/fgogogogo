<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <rect width="512" height="512" rx="80" fill="#0f172a"/>
  <rect x="20" y="20" width="472" height="472" rx="68" fill="#1e293b" stroke="#3b82f6" stroke-width="4"/>
  <!-- Dumbbell icon -->
  <g transform="translate(256,256)">
    <!-- Left weight -->
    <rect x="-140" y="-50" width="50" height="100" rx="12" fill="#3b82f6"/>
    <rect x="-160" y="-35" width="30" height="70" rx="8" fill="#60a5fa"/>
    <!-- Right weight -->
    <rect x="90" y="-50" width="50" height="100" rx="12" fill="#3b82f6"/>
    <rect x="130" y="-35" width="30" height="70" rx="8" fill="#60a5fa"/>
    <!-- Bar -->
    <rect x="-90" y="-12" width="180" height="24" rx="12" fill="#94a3b8"/>
    <!-- Center grip -->
    <rect x="-15" y="-16" width="30" height="32" rx="8" fill="#60a5fa"/>
  </g>
  <!-- Text -->
  <text x="256" y="420" text-anchor="middle" font-family="-apple-system,sans-serif" font-size="56" font-weight="800" fill="#f1f5f9">FitTrack</text>
</svg>
